<div class="card shadow-sm p-4">
  <%= simple_form_for restaurant do |f| %>
    <%= f.input :name, label: "Restaurant name" %>
    <%= f.input :address %>
    <%= f.input :phone_number %>
    <%= f.input :category, collection: Restaurant::CATEGORIES, prompt: "Choose a category" %>

    <%= f.submit class: "btn btn-success mt-3" %>
  <% end %>
</div>
