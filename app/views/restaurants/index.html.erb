<div class="container mt-4">
  <h1 class="mb-4 text-center">🍽️ Restaurants</h1>

  <div class="row">
    <% @restaurants.each do |restaurant| %>
      <div class="col-md-4 mb-4">
        <div class="card shadow-sm">
          <div class="card-body">
            <h4 class="card-title"><%= restaurant.name %></h4>
            <p class="card-text">
              <strong>Category:</strong> <%= restaurant.category.capitalize %><br>
              <strong>Address:</strong> <%= restaurant.address %>
            </p>
            <%= link_to "View details", restaurant_path(restaurant), class: "btn btn-primary btn-sm" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <div class="text-center mt-4">
    <%= link_to "➕ Add a new restaurant", new_restaurant_path, class: "btn btn-success" %>
  </div>
</div>
