<div class="container mt-4">

  <div class="card shadow-sm mb-4">
    <div class="card-body">
      <h1 class="card-title"><%= @restaurant.name %></h1>
      <p class="card-text">
        <strong>Category:</strong> <%= @restaurant.category.capitalize %><br>
        <strong>Address:</strong> <%= @restaurant.address %><br>
        <strong>Phone:</strong> <%= @restaurant.phone_number %>
      </p>
    </div>
  </div>

  <h2 class="mb-3">⭐ Reviews</h2>

  <% if @restaurant.reviews.any? %>
    <% @restaurant.reviews.each do |review| %>
      <div class="card mb-3 shadow-sm">
        <div class="card-body">
          <h5>Rating: <%= "⭐" * review.rating %></h5>
          <p><%= review.content %></p>
        </div>
      </div>
    <% end %>
  <% else %>
    <p>No reviews yet.</p>
  <% end %>

  <%= link_to "➕ Add a review", new_restaurant_review_path(@restaurant), class: "btn btn-primary mt-3" %>

  <div class="mt-4">
    <%= link_to "⬅ Back to list", restaurants_path, class: "btn btn-secondary" %>
  </div>

</div>
